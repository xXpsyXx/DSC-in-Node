<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DSC Helper</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="/css/service-dashboard.css" />
  </head>
  <body>
    
      <main id="app" class="dashboard-root">
        <section class="dashboard-grid">
          <section class="panel token-panel">
            <h3 class="panel-title">
              <span class="title-left">
                <span id="statusIndicator" class="panel-indicator-inline blue"></span>
                <span class="title-text">Token</span>
              </span>
              <span id="statusLabel" class="panel-status-label blue">Unknown</span>
            </h3>

            <div class="token-body">
              <div class="token-row">
                <div class="label">Certificate Name</div>
                <div id="certName" class="value">-</div>
              </div>
              <div class="token-row">
                <div class="label">Serial Number</div>
                <div id="serial" class="value">-</div>
              </div>
              <div class="token-row">
                <div class="label">Validity Date</div>
                <div id="validity" class="value">-</div>
              </div>
            </div>

            <div class="panel-spacer"></div>

            <div style="padding:12px 0;">
              <button id="unlockBtn" class="reveal">Unlock</button>
              <button id="clearCert" class="reveal" style="margin-left:8px;">Clear</button>
            </div>

            <div class="settings-body">
              <label class="setting-label">PKCS#11 Driver Path</label>
              <div style="display:flex; gap:8px; align-items:center;">
                <input id="driverPath" class="settings-input" type="text" placeholder="Driver path" />
                <input id="driverFileInput" type="file" style="display:none" />
              </div>
              <div style="display:flex; gap:8px; margin-top:8px;">
                <button id="browseDriver" class="reveal">Browse</button>
                <button id="saveDriver" class="reveal">Save</button>

              </div>
            </div>
          </section>

          <section class="panel activity-panel">
            <h3 class="panel-title">
              <span class="title-left"><span class="title-text">Logs</span></span>
              <button id="clearLogsBtn" class="reveal clear-topright">Clear Logs</button>
              <button id="refreshBtn" class="refresh-topright" title="Refresh">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="refresh-svg" focusable="false" aria-hidden="true">
                <path d="M23 4v6h-6" stroke="#cfe8ff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M1 20v-6h6" stroke="#cfe8ff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M3.51 9a9 9 0 0114.13-3.36L23 10" stroke="#cfe8ff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M20.49 15a9 9 0 01-14.13 3.36L1 14" stroke="#cfe8ff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            </h3>
            
            <div id="logs" class="logs-body">
              <div class="no-logs">Loading logs...</div>
            </div>
          </section>
        </section>
      </main>

      <div id="pinModal" class="modal-overlay" style="display:none;">
        <div class="modal-dialog">
          <h3 class="modal-title">Unlock Certificate</h3>
          <p class="modal-subtitle">Enter PIN to fetch certificate details.</p>
          <input id="pinInput" type="password" class="modal-input" placeholder="PIN" />
          <div class="modal-actions">
            <button id="cancelPin" class="btn">Cancel</button>
            <button id="confirmPin" class="btn primary">Confirm</button>
          </div>
        </div>
      </div>

      <div id="confirmModal" class="modal-overlay" style="display:none;">
        <div class="modal-dialog">
          <h3 class="modal-title">Confirm</h3>
          <p id="confirmModalSubtitle" class="modal-subtitle">Are you sure?</p>
          <div class="modal-actions">
            <button id="cancelClear" class="btn">Cancel</button>
            <button id="confirmClear" class="btn primary">Confirm</button>
          </div>
        </div>
      </div>

      <div id="responsePopup" class="response-popup" style="display:none;">
        <button id="responseClose" class="response-close">✕</button>
        <div id="responseContent" class="response-content"></div>
      </div>
 

    <script>window.apiBase = '<%= apiBase %>' || '/api';</script>
    <script src="/js/app.js"></script>
  </body>
</html>
