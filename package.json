{
  "name": "digital-signature-app",
  "version": "1.0.0",
  "description": "PDF Digital Signature with Hypersecu USB Token",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "electron:dev": "electron .",
    "pack": "electron-builder --dir --win",
    "dist": "electron-builder --win",
    "installer:prepare": "powershell -ExecutionPolicy Bypass -File scripts/build-installer-payload.ps1",
    "installer:build": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "build:ts": "tsc -p tsconfig.build.json",
    "obfuscate": "javascript-obfuscator dist --output dist --compact true --control-flow-flattening true --string-array true --string-array-rotate true --string-array-encoding base64 --transform-object-keys true",
    "build:obfuscate": "npm run build:ts && npm run obfuscate",
    "build": "tsc"
  },
  "keywords": [
    "pdf",
    "signature",
    "hypersecu",
    "dsc"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.63.0",
    "axios": "^1.7.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "ejs": "^3.1.9",
    "express": "^5.2.1",
    "formidable": "^3.5.1",
    "jsonwebtoken": "^9.0.3",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pkcs11js": "^2.1.6",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/formidable": "^3.4.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/node-forge": "^1.3.14",
    "javascript-obfuscator": "^5.4.1",
    "terser": "^5.46.1",
    "terser-webpack-plugin": "^5.4.0",
    "ts-loader": "^9.5.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2",
    "webpack-obfuscator": "^3.6.1",
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.example.digital-signature",
    "productName": "Digital Signature App",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "views/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis"]
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "msi": {
      "perMachine": false
    }
  }
}
