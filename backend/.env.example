# Example environment variables for DSC helper backend
# If you run the frontend dev server on a non-default port, set FRONTEND_URL
# or FRONTEND_PORT so the backend can configure CORS accordingly.

# Full origin (preferred):
FRONTEND_URL=http://localhost:45760,http://localhost:4200

# Or just the port (backend will form the localhost origin):
# FRONTEND_PORT=45760

# Server port (optional, defaults to 5000):
# PORT=5000
