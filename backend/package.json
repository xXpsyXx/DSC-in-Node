{
  "name": "backend",
  "version": "1.0.0",
  "description": "PDF Digital Signature with Hypersecu USB Token",
  "main": "index.js",
  "bin": "src/server.ts",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node node_modules/tsx/dist/cli.mjs src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/server.js",
    "obfuscate": "node obfuscate.js",
    "package": "node package-app.js",
    "full-build": "npm run obfuscate && npm run package",
    "service:install": "node service-install.js",
    "service:uninstall": "node service-uninstall.js",
    "installer:prepare": "powershell -ExecutionPolicy Bypass -File scripts/build-installer-payload.ps1",
    "installer:build": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1"
  },
  "keywords": [
    "pdf",
    "signature",
    "hypersecu",
    "dsc"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "axios": "^1.7.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "formidable": "^3.5.1",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pkcs11js": "^2.1.6",
    "sharp": "^0.33.5",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/formidable": "^3.4.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/node-forge": "^1.3.14",
    "@types/winston": "^2.4.4",
    "esbuild": "^0.28.0",
    "javascript-obfuscator": "^5.4.1",
    "node-windows": "^1.0.0-beta.8",
    "pkg": "^5.8.1",
    "typescript": "^6.0.2"
  }
}
