{
    "name":  "backend",
    "version":  "1.0.0",
    "description":  "PDF Digital Signature with Hypersecu USB Token",
    "main":  "dist/server.js",
    "scripts":  {
                    "dev":  "tsx src/server.ts",
                    "start":  "node dist/server.js",
                    "installer:prepare":  "powershell -ExecutionPolicy Bypass -File scripts/build-installer-payload.ps1",
                    "installer:build":  "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
                    "installer:build-advanced":  "powershell -ExecutionPolicy Bypass -File scripts/build-installer-advanced.ps1",
                    "build:ts":  "tsc -p tsconfig.build.json",
                    "obfuscate":  "javascript-obfuscator dist --output dist --compact true --control-flow-flattening true --string-array true --string-array-rotate true --string-array-encoding base64 --transform-object-keys true",
                    "build:obfuscate":  "npm run build:ts \u0026\u0026 npm run obfuscate",
                    "build:bundle":  "npm run build:ts \u0026\u0026 webpack --config webpack.bundle.config.js",
                    "obfuscate:bundle":  "javascript-obfuscator dist/bundle.js --output dist/bundle.obf.js --compact true --control-flow-flattening true --control-flow-flattening-threshold 0.75 --dead-code-injection true --dead-code-injection-threshold 0.4 --debug-protection true --debug-protection-interval 4000 --disable-console-output true --identifier-names-generator mangled --self-defending true --string-array true --string-array-rotate true --string-array-encoding base64 --string-array-threshold 0.75 --transform-object-keys true",
                    "build:bundle-obfuscate":  "npm run build:bundle \u0026\u0026 npm run obfuscate:bundle"
                },
    "keywords":  [
                     "pdf",
                     "signature",
                     "hypersecu",
                     "dsc"
                 ],
    "author":  "",
    "license":  "ISC",
    "dependencies":  {
                         "@signpdf/signpdf":  "^3.3.0",
                         "@types/cors":  "^2.8.19",
                         "asn1.js":  "^5.4.1",
                         "axios":  "^1.7.7",
                         "cors":  "^2.8.6",
                         "crypto-js":  "^4.2.0",
                         "dotenv":  "^17.4.1",
                         "express":  "^5.2.1",
                         "express-rate-limit":  "^8.3.2",
                         "formidable":  "^3.5.1",
                         "jsonwebtoken":  "^9.0.3",
                         "node-forge":  "^1.4.0",
                         "pdf-encrypt":  "^1.0.1",
                         "pdf-lib":  "^1.17.1",
                         "pdf-signer":  "^1.1.4",
                         "pkcs11js":  "^2.1.6",
                         "sharp":  "^0.33.5",
                         "tsx":  "^4.21.0",
                         "winston":  "^3.19.0"
                     },
    "devDependencies":  {
                            "@types/express":  "^5.0.6",
                            "@types/formidable":  "^3.4.5",
                            "@types/jsonwebtoken":  "^9.0.10",
                            "@types/node":  "^25.5.2",
                            "@types/node-forge":  "^1.3.14",
                            "@types/winston":  "^2.4.4",
                            "javascript-obfuscator":  "^5.4.1",
                            "terser":  "^5.46.1",
                            "terser-webpack-plugin":  "^5.4.0",
                            "ts-loader":  "^9.5.7",
                            "typescript":  "^6.0.2",
                            "webpack":  "^5.106.1",
                            "webpack-cli":  "^7.0.2",
                            "webpack-obfuscator":  "^3.6.1"
                        }
}
