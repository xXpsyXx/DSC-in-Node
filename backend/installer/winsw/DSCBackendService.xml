<service>
  <id>DSCBackendService</id>
  <name>DSC Backend Service</name>
  <description>DSC PDF signing backend service - runs under current user for USB token access</description>

  <executable>%BASE%\runtime\node.exe</executable>
  <arguments>"%BASE%\app\src\server.js"</arguments>
  <workingdirectory>%BASE%\app</workingdirectory>

  <!-- IMPORTANT: Service must run under logged-in user account to access USB token -->
  <!-- This allows PKCS#11 library to communicate with USB hardware -->
  <serviceaccount>
    <domain>.</domain>
    <user>%LocalUserName%</user>
  </serviceaccount>

  <startmode>Manual</startmode>
  <stoptimeout>15 sec</stoptimeout>

  <onfailure action="restart" delay="10 sec" />
  <onfailure action="restart" delay="10 sec" />
  <onfailure action="none" />

  <logpath>%BASE%\logs</logpath>
  <log mode="roll-by-size-time">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>14</keepFiles>
    <pattern>yyyyMMdd</pattern>
  </log>
</service>
